# Backend HTTP server
PORT=5000

# OpenAI server-side configuration (never commit a real key)
OPENAI_API_KEY=
OPENAI_MODEL=your-responses-api-model

# Local Docker PostgreSQL credentials only; never reuse in production
DATABASE_URL=postgresql://ai_business:local_dev_only_password@localhost:5432/ai_business_dev
TEST_DATABASE_URL=postgresql://ai_business:local_dev_only_password@localhost:5432/ai_business_test

# Local authentication configuration (replace secrets in every deployed environment)
JWT_SECRET=replace-me
JWT_ISSUER=ai-business-backend
JWT_AUDIENCE=ai-business-frontend
JWT_EXPIRY_SECONDS=900
PASSWORD_HASH_COST=12
